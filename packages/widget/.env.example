# Vite Environment Variables
# All environment variables must be prefixed with VITE_ to be exposed to the client

# Application version
VITE_VERSION=

# Hyperlane Registry Configuration
VITE_REGISTRY_URL=
VITE_REGISTRY_BRANCH=
VITE_GITHUB_PROXY=

# Wallet Configuration
VITE_WALLET_CONNECT_ID=your_wallet_connect_project_id_here

# Transfer Configuration
VITE_TRANSFER_BLACKLIST=

# Chain-specific wallet whitelists (JSON string)
VITE_CHAIN_WALLET_WHITELISTS={}

# RPC Overrides (JSON string)
VITE_RPC_OVERRIDES={}

# Leap API Base URL
VITE_LEAP_API_BASE_URL=

# Development mode override
VITE_NODE_ENV=