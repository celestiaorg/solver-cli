# OIF E2E Solver Configuration
# Copy to .env and fill in your values

# =============================================================================
# CHAIN CONFIGURATION
# =============================================================================
# The system supports any number of EVM chains. Configure each chain with:
#   {CHAIN}_RPC - RPC endpoint
#   {CHAIN}_PK - Private key for deploying/funding on this chain
#   {CHAIN}_CHAIN_ID - (optional) Chain ID override

# =============================================================================
# EVOLVE (Local Chain)
# =============================================================================
EVOLVE_RPC=http://127.0.0.1:8545
EVOLVE_CHAIN_ID=1234
# The Anvil default key
EVOLVE_PK=ac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# =============================================================================
# SEPOLIA (Testnet)
# =============================================================================
SEPOLIA_RPC=https://ethereum-sepolia-rpc.publicnode.com
SEPOLIA_CHAIN_ID=11155111
# IMPORTANT: This key must have Sepolia ETH for gas!
SEPOLIA_PK=your_private_key_here

# =============================================================================
# SOLVER & OPERATOR KEYS
# =============================================================================
# SOLVER_PRIVATE_KEY - Key used by solver to fill orders (defaults to SEPOLIA_PK)
# SOLVER_PRIVATE_KEY=...

# ORACLE_OPERATOR_PK - Key used by oracle operator to sign attestations
# Should be different from solver key in production (defaults to SEPOLIA_PK)
# ORACLE_OPERATOR_PK=...

# =============================================================================
# USER KEY
# =============================================================================
# USER_PK - Account that creates intents
# Using Anvil account #1 (has funds on local chain)
USER_PK=59c6995e998f97a5a0044966f0945389dc9e86dae88c7a8412f4603b6b78690d

# =============================================================================
# TOKEN CONFIGURATION
# =============================================================================
TOKEN_SYMBOL=USDC
TRANSFER_AMOUNT=1000000

# =============================================================================
# EXAMPLE: Adding a third chain (Arbitrum Sepolia)
# =============================================================================
# To add more chains:
#   ARBITRUM_RPC=https://sepolia-rollup.arbitrum.io/rpc
#   ARBITRUM_PK=your_key_here
#   ARBITRUM_CHAIN_ID=421614
#
# Then deploy with:
#   solver-cli deploy --chains evolve,sepolia,arbitrum
