# OIF E2E Solver Configuration
# Copy to .env and fill in your values

# =============================================================================
# RPC ENDPOINTS
# =============================================================================
SEPOLIA_RPC=https://ethereum-sepolia-rpc.publicnode.com
EVOLVE_RPC=http://127.0.0.1:8545

# =============================================================================
# CHAIN IDS
# =============================================================================
SEPOLIA_CHAIN_ID=11155111
EVOLVE_CHAIN_ID=1234

# =============================================================================
# PRIVATE KEYS (without 0x prefix)
# =============================================================================

# SEPOLIA_PK - THIS IS YOUR SOLVER KEY FOR BOTH CHAINS
# IMPORTANT: This key must have Sepolia ETH for gas!
# DO NOT use the Anvil default key - bots will drain your funds on public networks
SEPOLIA_PK=your_private_key_here

# EVOLVE_PK - Deployer for local Evolve chain
# The Anvil default key is fine here (local chain only)
EVOLVE_PK=ac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# USER_PK - Account that creates intents
# Using Anvil account #1 (has funds on local chain)
USER_PK=59c6995e998f97a5a0044966f0945389dc9e86dae88c7a8412f4603b6b78690d

# =============================================================================
# TOKEN CONFIGURATION
# =============================================================================
TOKEN_SYMBOL=USDC
TRANSFER_AMOUNT=1000000
