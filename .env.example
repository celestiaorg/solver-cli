# OIF E2E Solver Configuration
# Copy to .env and fill in your values

#SEPOLIA_RPC=https://ethereum-sepolia-rpc.publicnode.com
#SEPOLIA_CHAIN_ID=11155111
#SEPOLIA_PK=redacted

# =============================================================================
# RPC ENDPOINTS
# =============================================================================
ANVIL1_RPC=http://127.0.0.1:8545
ANVIL2_RPC=http://127.0.0.1:8546

# =============================================================================
# CHAIN IDS
# =============================================================================
ANVIL1_CHAIN_ID=31337
ANVIL2_CHAIN_ID=31338

# =============================================================================
# PRIVATE KEYS (without 0x prefix)
# =============================================================================

ORACLE_OPERATOR_PK=redacted

SOLVER_PRIVATE_KEY=redacted

# ANVIL1_PK - Deployer for local Anvil chain 1 (Anvil account #0)
# The Anvil default key is fine here (local chain only)
ANVIL1_PK=ac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# ANVIL2_PK - Deployer for local Anvil chain 2 (Anvil account #0 - same as ANVIL1_PK)
# Using the same key since both are local Anvil instances
ANVIL2_PK=ac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# USER_PK - Account that creates intents
USER_PK=3b100e493e845f3a316158400e765b3a75d92d9b922cf8e1d38b25e228a4d0a8

# =============================================================================
# TOKEN CONFIGURATION
# =============================================================================
TOKEN_SYMBOL=USDC
TRANSFER_AMOUNT=1000000

# =============================================================================
# CELESTIA / HYPERLANE CONFIGURATION
# =============================================================================
# Celestia node endpoints (used by Hyperlane relayer config generation)
CELESTIA_RPC=http://127.0.0.1:26657
CELESTIA_REST=http://127.0.0.1:1317
CELESTIA_GRPC=http://127.0.0.1:9090
CELESTIA_DOMAIN=69420

# Celestia signer key (hyp account from testnet init)
CELESTIA_SIGNER_KEY=0x6e30efb1d3ebd30d1ba08c8d5fc9b190e08394009dc1dd787a69e60c33288a8c

# =============================================================================
# OIF AGGREGATOR CONFIGURATION
# =============================================================================
# Secret key for integrity verification (min 32 chars)
INTEGRITY_SECRET=ed4eca56b4f1352acc8983460ac20068f1852b54a6b61715917af3e01a5fbda8
